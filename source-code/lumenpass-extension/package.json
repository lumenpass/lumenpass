{
  "name": "lumenpass-extension",
  "version": "1.0.5",
  "description": "LumenPass browser extension – autofill powered by LumenPass Desktop",
  "private": true,
  "type": "module",
  "scripts": {
    "generate:icons": "node scripts/generate-icons.mjs",
    "dev": "vite",
    "build": "npm run generate:icons && tsc && vite build",
    "build:edge": "npm run build && ./build-edge.sh",
    "build:firefox": "npm run generate:icons && tsc && BROWSER=firefox vite build",
    "build:safari": "npm run generate:icons && node scripts/build-safari.mjs",
    "sync:desktop": "node scripts/sync-desktop.mjs",
    "build:desktop-safari": "npm run build:safari && npm run sync:desktop",
    "convert:safari": "xcrun safari-web-extension-converter dist-safari/ --project-location ../lumenpass-safari --app-name LumenPass --bundle-identifier com.lumenpass.safari-extension --no-open",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.23",
    "@types/chrome": "^0.0.268",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@types/webextension-polyfill": "^0.10.7",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "sharp": "^0.33.5",
    "tailwindcss": "^3.4.12",
    "typescript": "^5.6.2",
    "vite": "^5.4.7",
    "vitest": "^4.1.5",
    "webextension-polyfill": "^0.12.0"
  }
}
